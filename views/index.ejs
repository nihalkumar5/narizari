<%- include('partials/header') %>

<main>
    <section class="hero-fs">
        <!-- Background Video -->
        <div class="hero-bg-wrapper">
            <video autoplay loop muted playsinline class="hero-video-fs">
                <source src="/assets/hero-video.mp4" type="video/mp4">
            </video>
            <div class="hero-overlay"></div>
        </div>

        <!-- Left Side Bar -->
        <div class="side-nav-left">
            <div class="follow-us-wrapper">
                <span class="vertical-text">Follow us</span>
                <div class="social-icons">
                    <a href="#"><img src="https://img.icons8.com/ios-glyphs/30/ffffff/instagram-new.png" alt="IG"></a>
                    <a href="#"><img src="https://img.icons8.com/ios-glyphs/30/ffffff/twitter.png" alt="X"></a>
                </div>
            </div>
        </div>



        <!-- Hero Content -->
        <div class="hero-container">
            <div class="hero-content-inner reveal">
                <!-- Script Subheading -->
                <div class="script-wrapper">
                    <div class="thin-line"></div>
                    <h2 class="script-text">Explore and Travel</h2>
                </div>

                <!-- Main Heading with Mask Effect -->
                <h1 class="main-heading">
                    Weaving <span class="masked">Intelligence</span>
                </h1>

                <!-- Body Text -->
                <p class="hero-subtext">
                    From Varanasi’s looms to the world’s digital storefronts. <br>
                    We build high-performing digital experiences for luxury Saree & Ethnicwear brands.
                </p>

                <!-- Scroll Down -->
                <div class="scroll-indicator">
                    <span>scroll down</span>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 13l5 5 5-5M12 18V6"></path></svg>
                </div>
            </div>
        </div>
    </section>

    <!-- About Section -->
    <section class="about-brief reveal">
        <div class="container">
            <h2 class="section-title">Hey, We're Narizari.</h2>
            <p class="about-text">
                We blend the timeless artistry of Banaras with bold digital creativity to craft solutions that don’t just look good — they deliver real, measurable growth. 
                Whether you're a legacy loom or a modern D2C startup, we create scalable, future-ready digital experiences that turn audiences into loyal patrons.
            </p>
        </div>
    </section>

    <!-- Detailed Services -->
    <section class="services-detailed reveal">
        <div class="container">
            <h2 class="section-label">Our Services - Crafted for Impact</h2>
            <div class="services-grid">
                <!-- Shopify/Ecom -->
                <div class="service-card">
                    <span class="service-no">01</span>
                    <h3>The Silk Suite</h3>
                    <p>Shopify Store Development & Theme Styling tailored for high-ticket ethnicwear. We handle everything from seamless platform migrations to conversion-optimized checkout experiences.</p>
                    <ul class="service-list">
                        <li>Store Development & Theme Styling</li>
                        <li>Shopify Website Redesigns</li>
                        <li>Seamless Platform Migrations</li>
                        <li>Speed & Performance Optimization</li>
                    </ul>
                </div>

                <!-- Marketing -->
                <div class="service-card">
                    <span class="service-no">02</span>
                    <h3>Intelligent Marketing</h3>
                    <p>Data-driven campaigns using SEO, PPC, and AI-powered social media strategies to connect with the modern Saree enthusiast and maximize your ROAS.</p>
                    <ul class="service-list">
                        <li>Luxury-focused SEO & Content Strategy</li>
                        <li>Google Ads (PPC) & Meta Campaigns</li>
                        <li>Social Media & Influencer Management</li>
                        <li>Email & WhatsApp Automations</li>
                    </ul>
                </div>

                <!-- Branding -->
                <div class="service-card">
                    <span class="service-no">03</span>
                    <h3>Creative Couture</h3>
                    <p>We craft bold identities and editorial stories that build trust and heritage. From packaging design to cinematic videography, we make your brand unmistakably yours.</p>
                    <ul class="service-list">
                        <li>Brand Strategy & Identity Design</li>
                        <li>Packaging & Print Design</li>
                        <li>Cinematic Photography & Videography</li>
                        <li>Creative Ad Design & Storyboarding</li>
                    </ul>
                </div>

                <!-- Strategy -->
                <div class="service-card">
                    <span class="service-no">04</span>
                    <h3>The Architects</h3>
                    <p>Scaling ethnicwear businesses with operational mastery and AI-powered solutions. We help you optimize operations and boost revenue with confidence.</p>
                    <ul class="service-list">
                        <li>Marketing & Growth Acceleration</li>
                        <li>Sales & Revenue Optimization</li>
                        <li>Operational Efficiency Improvement</li>
                        <li>AI-Powered Growth Solutions</li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- Impact Stats -->
    <section class="impact-stats reveal">
        <div class="container">
            <div class="stats-grid">
                <div class="stat-item">
                    <span class="stat-value">12x+</span>
                    <span class="stat-label">Average ROAS</span>
                </div>
                <div class="stat-item">
                    <span class="stat-value">7-Figure</span>
                    <span class="stat-label">Revenues for Saree Brands</span>
                </div>
                <div class="stat-item">
                    <span class="stat-value">150+</span>
                    <span class="stat-label">Stores Built & Launched</span>
                </div>
                <div class="stat-item">
                    <span class="stat-value">20K+</span>
                    <span class="stat-label">Qualified Leads Generated</span>
                </div>
            </div>
        </div>
    </section>
</main>

<%- include('partials/footer') %>
