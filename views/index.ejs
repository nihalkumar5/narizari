<%- include('partials/header') %>

<main>
    <section class="hero-fs">
        <!-- Background Video -->
        <div class="hero-bg-wrapper">
            <video autoplay loop muted playsinline class="hero-video-fs">
                <source src="/assets/hero-video.mp4" type="video/mp4">
            </video>
            <div class="hero-overlay"></div>
        </div>

        <!-- Left Side Bar -->
        <div class="side-nav-left">
            <div class="follow-us-wrapper">
                <span class="vertical-text">Follow us</span>
                <div class="social-icons">
                    <a href="#"><img src="https://img.icons8.com/ios-glyphs/30/ffffff/instagram-new.png" alt="IG"></a>
                    <a href="#"><img src="https://img.icons8.com/ios-glyphs/30/ffffff/twitter.png" alt="X"></a>
                </div>
            </div>
        </div>



        <!-- Hero Content -->
        <div class="hero-container">
            <div class="hero-content-inner reveal">


                <!-- Main Heading with Rotator -->
                <h1 class="main-heading">
                    Weaving <br>
                    <div class="rotator-wrapper">
                        <span class="rotate-text masked">Intelligence</span>
                        <span class="rotate-text masked">Heritage</span>
                        <span class="rotate-text masked">Growth</span>
                        <span class="rotate-text masked">Excellence</span>
                    </div>
                </h1>

                <!-- Body Text -->
                <p class="hero-subtext">
                    From Varanasi’s looms to the world’s digital storefronts. <br>
                    We build high-performing digital experiences for luxury Saree & Ethnicwear brands.
                </p>

        </div>

        <!-- Scroll Down -->
        <div class="scroll-indicator">
            <span>scroll down</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 13l5 5 5-5M12 18V6"></path></svg>
        </div>
    </section>

    <!-- About Section -->
    <section class="about-brief reveal">
        <div class="container">
            <h2 class="section-title">Hey, We're Narizari.</h2>
            <p class="about-text">
                We blend the timeless artistry of Banaras with bold digital creativity to craft solutions that don’t just look good — they deliver real, measurable growth. 
                Whether you're a legacy loom or a modern D2C startup, we create scalable, future-ready digital experiences that turn audiences into loyal patrons.
            </p>
        </div>
    </section>

    <!-- Our Services - Crafted for Impact -->
    <section class="services-impact reveal">
        <div class="container">
            <div class="services-header">
                <h2 class="section-title">Our Services - Crafted for Impact</h2>
                <p class="section-subtitle">This isn't a list of "services." It's a toolkit built to make your brand unforgettable — and unstoppable</p>
            </div>

            <!-- Service Row 1: Shopify -->
            <div class="impact-row reveal">
                <div class="impact-content">
                    <span class="service-tag">Shopify</span>
                    <h3>Your Store, Your Brand — Built for Growth</h3>
                    <p class="impact-desc">Whether you’re starting from scratch or upgrading an existing site, we craft high-performance Shopify stores that blend legacy aesthetics with modern conversion science.</p>
                    <ul class="impact-features">
                        <li>Bespoke Theme Development</li>
                        <li>Global Multi-Currency & Logistics</li>
                        <li>High-Speed Performance Audit</li>
                    </ul>
                    <a href="/services" class="text-link">Explore the Silk Suite →</a>
                </div>
                <div class="impact-visual">
                    <img src="/shopify_luxury_saree_composition_1778581636038.png" alt="Shopify Suite" class="rounded-visual">
                </div>
            </div>

            <!-- Service Row 2: Digital Marketing -->
            <div class="impact-row reverse reveal">
                <div class="impact-content">
                    <span class="service-tag">Growth</span>
                    <h3>Digital Marketing — Precision & Scale</h3>
                    <p class="impact-desc">We don't just run ads; we engineer growth. Our AI-driven marketing suites identify your most valuable customers and keep them coming back.</p>
                    <ul class="impact-features">
                        <li>12x+ Average ROAS</li>
                        <li>Performance SEO for Luxury</li>
                        <li>VIP WhatsApp Automations</li>
                    </ul>
                    <a href="/services" class="text-link">See Intelligent Marketing →</a>
                </div>
                <div class="impact-visual">
                    <img src="/hero_saree_luxury_1778574360191.png" alt="Marketing Intelligence" class="rounded-visual">
                </div>
            </div>

            <!-- Service Row 3: Branding -->
            <div class="impact-row reveal">
                <div class="impact-content">
                    <span class="service-tag">Creative</span>
                    <h3>Creative Couture — Editorial Branding</h3>
                    <p class="impact-desc">Your heritage deserves a story that captivates. We build visual identities and cinematic content that position your brand at the pinnacle of luxury.</p>
                    <ul class="impact-features">
                        <li>Visual Identity Design</li>
                        <li>Cinematic Film Production</li>
                        <li>Editorial Storytelling</li>
                    </ul>
                    <a href="/services" class="text-link">View Creative Couture →</a>
                </div>
                <div class="impact-visual">
                    <img src="/saree_fashion_editorial_1778574464550.png" alt="Editorial Branding" class="rounded-visual">
                </div>
            </div>
        </div>
    </section>

    <!-- Impact Stats -->
    <section class="impact-stats reveal">
        <div class="container">
            <div class="stats-grid">
                <div class="stat-item">
                    <span class="stat-value">12x+</span>
                    <span class="stat-label">Average ROAS</span>
                </div>
                <div class="stat-item">
                    <span class="stat-value">7-Figure</span>
                    <span class="stat-label">Revenues for Saree Brands</span>
                </div>
                <div class="stat-item">
                    <span class="stat-value">150+</span>
                    <span class="stat-label">Stores Built & Launched</span>
                </div>
                <div class="stat-item">
                    <span class="stat-value">20K+</span>
                    <span class="stat-label">Qualified Leads Generated</span>
                </div>
            </div>
        </div>
    </section>
</main>

<%- include('partials/footer') %>
