<%- include('partials/header') %>

<main>
    <section class="hero-fs">
        <!-- Background Video -->
        <div class="hero-bg-wrapper">
            <video autoplay loop muted playsinline class="hero-video-fs">
                <source src="/assets/hero-video.mp4" type="video/mp4">
            </video>
            <div class="hero-overlay"></div>
        </div>

        <!-- Left Side Bar -->
        <div class="side-nav-left">
            <div class="follow-us-wrapper">
                <span class="vertical-text">Follow us</span>
                <div class="social-icons">
                    <a href="#"><img src="https://img.icons8.com/ios-glyphs/30/ffffff/instagram-new.png" alt="IG"></a>
                    <a href="#"><img src="https://img.icons8.com/ios-glyphs/30/ffffff/twitter.png" alt="X"></a>
                </div>
            </div>
        </div>



        <!-- Hero Content -->
        <div class="hero-container">
            <div class="hero-content-inner reveal">
                <!-- Script Subheading -->
                <div class="script-wrapper">
                    <div class="thin-line"></div>
                    <h2 class="script-text">Explore and Travel</h2>
                </div>

                <!-- Main Heading with Mask Effect -->
                <h1 class="main-heading">
                    Let's Go <span class="masked">Now</span>
                </h1>

                <!-- Body Text -->
                <p class="hero-subtext">
                    Bespoke AI strategies for the global Varanasi silk industry, <br>
                    shaped around tradition, technology, and pure luxury.
                </p>

                <!-- Scroll Down -->
                <div class="scroll-indicator">
                    <span>scroll down</span>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 13l5 5 5-5M12 18V6"></path></svg>
                </div>
            </div>
        </div>
    </section>

    <!-- Platform Partners -->
    <section class="platform-partners reveal">
        <div class="container">
            <div class="partners-header">
                <p class="partners-label">Partnering with leading platforms</p>
                <div class="partners-line"></div>
            </div>
            <div class="partners-grid">
                <div class="partner-item">
                    <span class="p-icon">▲</span> Google Ads
                </div>
                <div class="partner-item">
                    <span class="p-icon">♪</span> TikTok <span class="p-sub">Marketing Partner</span>
                </div>
                <div class="partner-item">
                    <span class="p-icon">🛍️</span> shopify <span class="p-sub">partners</span>
                </div>
                <div class="partner-item">
                    <span class="p-icon">∞</span> Meta <span class="p-sub">Business Partner</span>
                </div>
                <div class="partner-item">
                    <span class="p-icon">👻</span> snapchat
                </div>
            </div>
        </div>
    </section>
</main>

<%- include('partials/footer') %>
