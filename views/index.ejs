<%- include('partials/header') %>

<main>
    <section class="hero">
        <div class="container hero-content">
            <div class="reveal">
                <p class="hero-tagline">Heritage x Intelligence</p>
                <h1>The Art of <br><span>Digital Silk</span></h1>
                <p style="max-width: 450px; color: var(--text-secondary); margin-bottom: 40px; font-size: 16px; font-weight: 100; letter-spacing: 0.02em;">
                    Narizari is a bespoke AI marketing laboratory dedicated to the preservation and global expansion of Varanasi's silk legacy.
                </p>
                <a href="/services" class="btn-premium">Explore Strategies</a>
            </div>
        </div>
        <div class="hero-image-container">
            <img src="/assets/hero-silk.png" alt="Luxury Varanasi Silk" class="hero-image">
        </div>
    </section>

    <section class="platform-partners reveal">
        <div class="container">
            <div class="partners-header">
                <p class="partners-label">Partnering with leading platforms</p>
                <div class="partners-line"></div>
            </div>
            <div class="partners-grid">
                <div class="partner-item">
                    <span class="p-icon">▲</span> Google Ads
                </div>
                <div class="partner-item">
                    <span class="p-icon">♪</span> TikTok <span class="p-sub">Marketing Partner</span>
                </div>
                <div class="partner-item">
                    <span class="p-icon">🛍️</span> shopify <span class="p-sub">partners</span>
                </div>
                <div class="partner-item">
                    <span class="p-icon">∞</span> Meta <span class="p-sub">Business Partner</span>
                </div>
                <div class="partner-item">
                    <span class="p-icon">👻</span> snapchat
                </div>
            </div>
        </div>
    </section>

</main>

<%- include('partials/footer') %>
